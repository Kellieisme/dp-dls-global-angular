{
  "name": "@dasdigitalplatform/dls-global-angular",
  "version": "2.5.9",
  "main": "dist/design/dls-global-angular/index.d.ts",
  "files": [
    "dist/design/dls-global-angular"
  ],
  "scripts": {
    "start": "npm-run-all clean --parallel lib:watch demo:start-waiton",
    "build": "run-s lib:build demo:build",
    "release": "run-s lib:build",
    "test": "run-p lib:test demo:test",
    "lint:lib": "eslint ./projects/design",
    "lib:build": "ng build @dasdigitalplatform/dls-global-angular",
    "lib:watch": "ng build @dasdigitalplatform/dls-global-angular --watch --configuration development",
    "lib:test": "ng test @dasdigitalplatform/dls-global-angular --code-coverage",
    "lib:ci_test": "ng test @dasdigitalplatform/dls-global-angular --browsers=ChromeHeadless --watch=false",
    "demo:start-waiton": "wait-on dist/design/dls-global-angular/package.json --delay 5000 && npm run demo:start",
    "demo:start": "ng serve demo",
    "lint:demo": "eslint ./projects/demo",
    "demo:build": "ng build demo",
    "demo:watch": "ng build demo --watch --configuration development",
    "demo:test": "ng test demo",
    "demo:ci_test": "ng test demo --browsers=ChromeHeadless --watch=false",
    "clean": "rimraf dist",
    "storybook": "ng run @dasdigitalplatform/dls-global-angular:storybook",
    "build-storybook": "ng run @dasdigitalplatform/dls-global-angular:build-storybook",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s",
    "version-release": "standard-version && npm run changelog && npm run update-subfolder-version",
    "update-subfolder-version": "cd projects/design/dls-global-angular && npm version $(node -p \"require('../../../package.json').version\") --no-git-tag-version"
  },
  "dependencies": {
    "@angular-devkit/core": "^18.2.14",
