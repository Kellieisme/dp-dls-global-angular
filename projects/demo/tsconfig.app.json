/* To learn more about this file see: https://angular.io/config/tsconfig. */
{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "paths": {
      "@design/dls-global-angular/*": [
        "./../../dist/design/dls-global-angular/*"
      ],
      "@design/dls-global-angular": [
        "./../../dist/design/dls-global-angular"
      ]
    },
    "experimentalDecorators": true,
    "outDir": "../../out-tsc/app",
